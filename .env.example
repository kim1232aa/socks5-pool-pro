# Host-side ports. Both remain bound to 127.0.0.1 by compose.yaml.
SOCKS_PORT=1080
DASHBOARD_PORT=8080

# Optional inbound SOCKS5 authentication. Set or clear the pair together.
SOCKS_USER=
SOCKS_PASS=

# Optional dashboard and management API authentication. Set or clear together.
# Enabling this also protects /api/status; update machine consumers first.
ADMIN_USER=
ADMIN_PASS=

# Refresh and health-check budgets.
MAX_CONCURRENT=50
MAX_CANDIDATES=1500
MAX_CLIENT_CONNECTIONS=512
SCRAPE_INTERVAL=20m
CHECK_TIMEOUT=10s
REQUIRE_IP_CHANGE=true
GOMEMLIMIT=1200MiB
GOGC=75
